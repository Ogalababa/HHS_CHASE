  OmniplusBusProvider ..|> BusProviderPort
  BusPlanningParquetProvider ..|> PlanningProviderPort
  ConnectorJsonInfrastructureProvider ..|> InfrastructureProviderPort
  OmniplusBusProvider --> OmniplusOnClient
  MaximoAssetProvider --> DataLakeConfig
  BusPlanningParquetProvider --> DataLakeConfig
